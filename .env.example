DEBUG=true
SECRET_KEY=change-me
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=
TIME_ZONE=UTC

# Use SQLite by default. Set DATABASE_URL for Postgres on Railway.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=false

# DRF throttling
THROTTLE_ANON_RATE=120/hour
THROTTLE_USER_RATE=1200/hour
THROTTLE_EXPORT_RATE=20/hour
