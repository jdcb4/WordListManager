DEBUG=false
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
TIME_ZONE=UTC

# Use SQLite by default. Set DATABASE_URL for Postgres on Railway.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=false

# Gunicorn runtime tuning (important for long-running AI management calls)
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=300
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5

# DRF throttling
THROTTLE_ANON_RATE=120/hour
THROTTLE_USER_RATE=1200/hour
THROTTLE_EXPORT_RATE=20/hour

# AI features (OpenRouter)
OPEN_ROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# React UI handoff
# Default mode in this project is React-first on all non-admin pages.
REACT_UI_ENABLED=true
# Legacy compatibility flag for manage pages (optional fallback).
REACT_MANAGE_UI_ENABLED=false
REACT_UI_BASE_URL=
