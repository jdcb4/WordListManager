DEBUG=true
SECRET_KEY=change-me
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=
# On Railway, host checks default to permissive mode to satisfy internal healthchecks.
# Set this to true only if you want strict ALLOWED_HOSTS enforcement.
RAILWAY_STRICT_HOST_CHECK=false
TIME_ZONE=UTC

# Use SQLite by default. Set DATABASE_URL for Postgres on Railway.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=false

# DRF throttling
THROTTLE_ANON_RATE=120/hour
THROTTLE_USER_RATE=1200/hour
THROTTLE_EXPORT_RATE=20/hour
